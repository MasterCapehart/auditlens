# PKG-04 FIX: exclude development artifacts from the packaged .vsix

# Source files (keep only compiled output)
src/
tsconfig.json
.vscode/
.vscodeignore

# Node.js dev artifacts
node_modules/

# Old packaged extensions — should be generated by CI, not committed
*.vsix

# Temporary / debug files
temp.json
*.log
.DS_Store
Thumbs.db

# Test / coverage artifacts
coverage/
*.lcov

# Git metadata
.git/
.gitignore
